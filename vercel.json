{
  "redirects": [
    { "source": "/learn", "destination": "/library", "permanent": true },
    { "source": "/learn/:slug", "destination": "/library/:slug", "permanent": true },

    { "source": "/trojan", "destination": "https://t.me/achilles_trojanbot?start=r-ozgnos", "permanent": false },
    { "source": "/maestro", "destination": "https://t.me/maestro?start=r-ozgnos", "permanent": false },
    { "source": "/floki", "destination": "https://t.me/floki_trading_bot?start=ODc4NzEzODY3Ng==", "permanent": false },
    { "source": "/solbot", "destination": "https://t.me/SolanaTradingBot?start=DdQc46SDM", "permanent": false },

    { "source": "/binance", "destination": "https://www.binance.com/register?ref=DRM7E47L", "permanent": false },
    { "source": "/mexc", "destination": "https://promote.mexc.com/r/hx2XgcApER", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
